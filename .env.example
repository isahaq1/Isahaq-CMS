# Database
DATABASE_URL="postgresql://groupcms:groupcms_secret@localhost:5433/group_cms?schema=public"

# API
API_PORT=4000
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
